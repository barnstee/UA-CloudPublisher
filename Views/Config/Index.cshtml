@using Opc.Ua.Cloud.Publisher.Models

@model Settings

@{
    ViewData["Title"] = "Configuration";
}

<div class="page-header">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <div class="page-subtitle">Manage certificates, broker connectivity, and publisher behavior.</div>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-file-upload"></i> Custom MQTT Client Certificate</h3>
    <p class="card-subtitle">
        By default, the OPC UA client cert is also used as the MQTT client cert. A custom MQTT client cert can be loaded here.
    </p>
    <form method="post" enctype="multipart/form-data" asp-controller="Config" asp-action="LocalCertOpen">
        <p>
            <input class="modern-input" type="file" name="file" accept=".pfx,.der">
        </p>
        <p>
            <input class="btn btn-primary" type="submit" value="Load">
        </p>
    </form>
</div>

<form action="/Config/Apply" method="post">

    <div class="app-card">
        <h3 class="card-title"><i class="fas fa-shield-alt"></i> Certificate Status</h3>

        <p>
            OPC UA Client Certificate Thumbprint
            @Html.TextBox("UAClientCertThumbprint", @Model.UAClientCertThumbprint, new { @class = "modern-input", @readonly = "readonly" })
        </p>
        <p>
            OPC UA Client Certificate Expiry
            @Html.TextBox("UAClientCertExpiry", @Model.UAClientCertExpiry, new { @class = "modern-input", @readonly = "readonly" })
        </p>
        <p>
            OPC UA Issuer Certificate Thumbprint
            @Html.TextBox("UAIssuerCertThumbprint", @Model.UAIssuerCertThumbprint, new { @class = "modern-input", @readonly = "readonly" })
        </p>
        <p>
            OPC UA Issuer Certificate Expiry
            @Html.TextBox("UAIssuerCertExpiry", @Model.UAIssuerCertExpiry, new { @class = "modern-input", @readonly = "readonly" })
        </p>
        <p>
            MQTT Client Certificate Thumbprint
            @Html.TextBox("MQTTClientCertThumbprint", @Model.MQTTClientCertThumbprint, new { @class = "modern-input", @readonly = "readonly" })
        </p>
        <p>
            MQTT Client Certificate Expiry
            @Html.TextBox("MQTTClientCertExpiry", @Model.MQTTClientCertExpiry, new { @class = "modern-input", @readonly = "readonly" })
        </p>
    </div>

    <div class="app-card">
        <h3 class="card-title"><i class="fas fa-broadcast-tower"></i> Broker Connection</h3>

        <p>
            Publisher Name (<b>required</b>)
            @Html.TextBox("PublisherName", @Model.PublisherName, new { @class = "modern-input" })
        </p>
        <p>
            Broker URL (<b>required</b>)
            @Html.TextBox("BrokerUrl", @Model.BrokerUrl, new { @class = "modern-input" })
        </p>
        <p>
            Broker Port (<b>required</b>)
            @Html.TextBox("BrokerPort", @Model.BrokerPort, new { @class = "modern-input" })
        </p>
        <p>
            Broker Username (<b>required</b>)
            @Html.TextBox("BrokerUsername", @Model.BrokerUsername, new { @class = "modern-input" })
        </p>
        <p>
            Broker Password (<b>required</b>)
            @Html.Password("BrokerPassword", @Model.BrokerPassword, new { @class = "modern-input" })
        </p>
        <p>
            Broker Message Topic (<b>required</b>)
            @Html.TextBox("BrokerMessageTopic", @Model.BrokerMessageTopic, new { @class = "modern-input" })
        </p>
        <p>
            <label>@Html.CheckBox("UseTLS", @Model.UseTLS) Use TLS with Broker (when switching off TLS, you will most likely also need to update the Broker Port)</label>
        </p>
        <p>
            <label>@Html.CheckBox("UseKafka", @Model.UseKafka) Use Kafka</label>
        </p>
        <p>
            <label>@Html.CheckBox("CreateBrokerSASToken", @Model.CreateBrokerSASToken) Create Broker SAS Token</label>
        </p>
        <p>
            <label>@Html.CheckBox("UseUACertAuth", @Model.UseUACertAuth) Use OPC UA certificate for authentication with Broker</label>
        </p>
        <p>
            <label>@Html.CheckBox("UseCustomCertAuth", @Model.UseCustomCertAuth) Use custom certificate for authentication with Broker (loaded above)</label>
        </p>
        <p>
            Broker Message Size
            @Html.TextBox("BrokerMessageSize", @Model.BrokerMessageSize, new { @class = "modern-input" })
        </p>
        <p>
            Broker Command Topic
            @Html.TextBox("BrokerCommandTopic", @Model.BrokerCommandTopic, new { @class = "modern-input" })
        </p>
        <p>
            Broker Data Received Topic
            @Html.TextBox("BrokerDataReceivedTopic", @Model.BrokerDataReceivedTopic, new { @class = "modern-input" })
        </p>
        <p>
            Broker Command Response Topic
            @Html.TextBox("BrokerResponseTopic", @Model.BrokerResponseTopic, new { @class = "modern-input" })
        </p>
        <p>
            <label>@Html.CheckBox("SendUAMetadata", @Model.SendUAMetadata) Send OPC UA Metadata Messages</label>
        </p>
        <p>
            Broker Metadata Topic
            @Html.TextBox("BrokerMetadataTopic", @Model.BrokerMetadataTopic, new { @class = "modern-input" })
        </p>
        <p>
            Metadata Send Interval in Seconds
            @Html.TextBox("MetadataSendInterval", @Model.MetadataSendInterval, new { @class = "modern-input" })
        </p>
        <p>
            <label>@Html.CheckBox("UseCloudEventsMetadataHeader", @Model.UseCloudEventsMetadataHeader) Use CloudEvents header for metadata messages (instead of OPC UA PubSub NetworkMessage header, see <a href="https://github.com/cloudevents/spec/blob/main/cloudevents/extensions/opcua.md" target="_blank" rel="noopener">here</a>)</label>
        </p>
        <p>
            <label>@Html.CheckBox("UseAltBrokerForMetadata", @Model.UseAltBrokerForMetadata) Use Alternative Broker For OPC UA Metadata Messages</label>
        </p>
        <p>
            <label>@Html.CheckBox("SendUAStatus", @Model.SendUAStatus) Send OPC UA Status Messages</label>
        </p>
    </div>

    <div class="app-card">
        <h3 class="card-title"><i class="fas fa-server"></i> Alternative Broker &amp; Metadata</h3>

        <p>
            Alternative Broker URL
            @Html.TextBox("AltBrokerUrl", @Model.AltBrokerUrl, new { @class = "modern-input" })
        </p>
        <p>
            Alternative Broker Port
            @Html.TextBox("AltBrokerPort", @Model.AltBrokerPort, new { @class = "modern-input" })
        </p>
        <p>
            Alternative Broker Username
            @Html.TextBox("AltBrokerUsername", @Model.AltBrokerUsername, new { @class = "modern-input" })
        </p>
        <p>
            Alternative Broker Password
            @Html.Password("AltBrokerPassword", @Model.AltBrokerPassword, new { @class = "modern-input" })
        </p>
        <p>
            <label>@Html.CheckBox("UseKafkaForAlt", @Model.UseKafkaForAlt) Use Kafka for Alternative Broker</label>
        </p>
    </div>

    <div class="app-card">
        <h3 class="card-title"><i class="fas fa-cogs"></i> Publisher Behavior</h3>

        <p>
            <label>@Html.CheckBox("UseReverseConnect", @Model.UseReverseConnect) Use reverse connect to connect to OPC UA servers. UA Cloud Publisher will listen on port 50000.</label>
        </p>
        <p>
            <label>@Html.CheckBox("AutoPublishAllWoTProperties", @Model.AutoPublishAllWoTProperties) Auto-publish all WoT properties</label>
        </p>
        <p>
            <label>@Html.CheckBox("PushCertsBeforePublishing", @Model.PushCertsBeforePublishing) Push new OPC UA certificates to server before WoT file upload or before processing published nodes files (GDS Server Push feature)</label>
        </p>
        <p>
            <label>@Html.CheckBox("ReversiblePubSubEncoding", @Model.ReversiblePubSubEncoding) Use Reversible PubSub Encoding</label>
        </p>
        <p>
            <label>@Html.CheckBox("OmitNetworkMessageHeader", @Model.OmitNetworkMessageHeader) Omit PubSub NetworkMessage Header (when checked, telemetry is sent as a bare JSON array of DataSetMessages)</label>
        </p>
        <p>
            <label>@Html.CheckBox("AutoLoadPersistedNodes", @Model.AutoLoadPersistedNodes) Auto-Load Previously Published Nodes on Startup</label>
        </p>
        <p>
            Internal Queue Capacity
            @Html.TextBox("InternalQueueCapacity", @Model.InternalQueueCapacity, new { @class = "modern-input" })
        </p>
        <p>
            Default Send Interval in Seconds
            @Html.TextBox("DefaultSendIntervalSeconds", @Model.DefaultSendIntervalSeconds, new { @class = "modern-input" })
        </p>
        <p>
            Diagnostics Logging Interval in Seconds
            @Html.TextBox("DiagnosticsLoggingInterval", @Model.DiagnosticsLoggingInterval, new { @class = "modern-input" })
        </p>
        <p>
            Default OPC UA Sampling Interval in Milliseconds
            @Html.TextBox("DefaultOpcSamplingInterval", @Model.DefaultOpcSamplingInterval, new { @class = "modern-input" })
        </p>
        <p>
            Default OPC UA Publishing Interval in Milliseconds
            @Html.TextBox("DefaultOpcPublishingInterval", @Model.DefaultOpcPublishingInterval, new { @class = "modern-input" })
        </p>
        <p>
            OPC UA Stack Trace Mask
            @Html.TextBox("UAStackTraceMask", @Model.UAStackTraceMask, new { @class = "modern-input" })
        </p>
    </div>

    <div class="app-card">
        <h3 class="card-title"><i class="fas fa-robot"></i> Azure OpenAI</h3>

        <p>
            Azure OpenAI API Endpoint, e.g. https://wotgpt4.openai.azure.com/
            @Html.TextBox("AzureOpenAIAPIEndpoint", @Model.AzureOpenAIAPIEndpoint, new { @class = "modern-input" })
        </p>
        <p>
            Azure OpenAI API Key
            @Html.TextBox("AzureOpenAIAPIKey", @Model.AzureOpenAIAPIKey, new { @class = "modern-input" })
        </p>
        <p>
            Azure OpenAI Deployment or Model Name
            @Html.TextBox("AzureOpenAIDeploymentName", @Model.AzureOpenAIDeploymentName, new { @class = "modern-input" })
        </p>
    </div>

    <div class="app-card" style="position:sticky;bottom:1rem;">
        <input class="btn btn-primary" type="submit" name="Apply" value="Apply Changes" />
    </div>
</form>
