@using Opc.Ua.Cloud.Publisher.Models

@model CertManagerModel

@{
    ViewData["Title"] = "Certificate Management";
}

<div class="page-header">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <div class="page-subtitle">Manage the OPC UA trust list and encrypt sensitive values used in publishednodes.json.</div>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-list"></i> Trust List</h3>
    <p class="card-subtitle">Certificates currently in the trust list:</p>
    <p>
        @Html.ListBox("trust list certificates", Model.Certs, new { disabled = "disabled", size = 8 })
    </p>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-upload"></i> Load Certificate Into Trust List</h3>
    <form method="post" enctype="multipart/form-data" asp-controller="CertManager" asp-action="Load">
        <p>
            <input class="modern-input" type="file" name="file">
        </p>
        <p>
            <input class="btn btn-primary" type="submit" value="Load">
        </p>
    </form>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-download"></i> Download Trust List</h3>
    @using (Html.BeginForm("DownloadTrustlist", "CertManager"))
    {
        <p>
            <input class="btn btn-secondary" type="submit" value="Download Trust List" />
        </p>
    }
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-key"></i> Encrypt String</h3>
    <p class="card-subtitle">
        Encrypt a string (for example, the password for the user specified in publishednodes.json).
    </p>
    <form method="post" enctype="multipart/form-data" asp-controller="CertManager" asp-action="EncryptString">
        <p>
            Plain text
            @Html.TextBox("plainTextString", "", new { @class = "modern-input" })
        </p>
        <p>
            <input class="btn btn-primary" type="submit" value="Encrypt">
        </p>
        <p>
            Encrypted String (Base64-encoded)
            <span class="modern-input" style="display:block;min-height:2.4rem;word-break:break-all;">
                @(string.IsNullOrEmpty(Model.Encrypt) ? "N/A" : Model.Encrypt)
            </span>
        </p>
    </form>
</div>
