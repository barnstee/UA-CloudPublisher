@using Opc.Ua.Cloud.Publisher.Models

@model SessionModel

@{
    ViewData["Title"] = "Connect to an OPC UA Server";
}

<div class="page-header">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <div class="page-subtitle">Provide credentials for the OPC UA server. Leave blank for anonymous access.</div>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-user-shield"></i> Credentials</h3>
    <form method="post" enctype="multipart/form-data" asp-controller="Browser" asp-action="Connect">
        <p>
            User Name
            @Html.TextBox("username", null, new { @class = "modern-input", autocomplete = "off" })
        </p>
        <p>
            Password
            @Html.Password("password", null, new { @class = "modern-input", autocomplete = "new-password" })
        </p>
        @Html.Hidden("endpointUrl", @Model.EndpointUrl)
        <p>
            <input id="connectButton" class="btn btn-primary" type="submit" value="Connect">
        </p>
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <p class="uacp-status-error">@Model.StatusMessage</p>
        }
    </form>
</div>
