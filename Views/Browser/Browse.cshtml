@using Opc.Ua.Cloud.Publisher.Models
@using Opc.Ua.Cloud.Publisher.Pages

@model SessionModel

@{
    ViewData["Title"] = "Browse, Read & Select Telemetry for Publishing to the Cloud";
}

<div class="page-header">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <div class="page-subtitle">Navigate the server's address space, read values, and select variables to publish.</div>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-sitemap"></i> Address Space</h3>
    <component>@(await Html.RenderComponentAsync<UABrowser>(
        RenderMode.Server,
        new
        {
            EndpointUrl = Model.EndpointUrl,
            Username = Model.UserName,
            Password = Model.Password,
            StatusMessage = Model.StatusMessage
        }).ConfigureAwait(false))</component>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-tools"></i> Session Actions</h3>

    <div class="action-group export-group">
        <h4 class="action-group-title">Export</h4>
        <div class="row browser_browse_generate_pn_button">
            @using (Html.BeginForm("GeneratePN", "Browser"))
            {
                <input class="btn btn-primary" type="submit" value="Generate publishednodes.json file from all OPC UA variables in the server" />
            }
        </div>
        <div class="row browser_browse_generate_csv_button">
            @using (Html.BeginForm("GenerateCSV", "Browser"))
            {
                <input class="btn btn-primary" type="submit" value="Generate CSV file from all OPC UA variables in the server" />
            }
        </div>
        <div class="row browser_browse_generate_nodeset_button">
            @using (Html.BeginForm("GenerateNodeSet", "Browser", FormMethod.Post, new { @class = "nodeset-export-form" }))
            {
                <div class="nodeset-export-controls">
                    <input class="btn btn-primary" type="submit" value="Generate Nodeset2.xml file from all OPC UA variables in the selected namespace:" />
                    <select id="namespaceUri" name="namespaceUri" class="form-control">
                        @foreach (string ns in Model.Namespaces)
                        {
                            <option value="@ns">@ns</option>
                        }
                    </select>
                </div>
            }
        </div>
    </div>

    <div class="action-group server-group">
        <h4 class="action-group-title">Server</h4>
        <div class="row browser_browse_gds_push_button">
            @using (Html.BeginForm("PushCert", "Browser"))
            {
                <input class="btn btn-primary" type="submit" value="Send new certificate and trust list to the server (GDS Server Push)" />
            }
        </div>
        <div class="row browser_browse_disconnect_button">
            @using (Html.BeginForm("Disconnect", "Browser"))
            {
                <input id="disconnectButton" class="btn btn-secondary" type="submit" value="Disconnect" />
            }
        </div>
    </div>
</div>

<div id="nodesetSpinnerOverlay" class="spinner-overlay" hidden>
    <div class="spinner-box">
        <i class="fas fa-spinner fa-spin spinner-icon"></i>
        <div class="spinner-text">Generating nodeset, please wait&hellip;</div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var form = document.querySelector('.nodeset-export-form');
            var overlay = document.getElementById('nodesetSpinnerOverlay');
            if (!form || !overlay) {
                return;
            }

            function readCookie(name) {
                var match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
                return match ? decodeURIComponent(match[1]) : null;
            }

            form.addEventListener('submit', function () {
                // the server echoes this token as a cookie once the file response is ready; poll for it to hide the spinner
                var token = 'nodeset-' + Date.now();
                var field = document.createElement('input');
                field.type = 'hidden';
                field.name = 'downloadToken';
                field.value = token;
                form.appendChild(field);

                overlay.hidden = false;

                var poll = setInterval(function () {
                    if (readCookie('nodesetDownloadToken') === token) {
                        clearInterval(poll);
                        overlay.hidden = true;
                        // clear the token cookie so it does not affect the next download
                        document.cookie = 'nodesetDownloadToken=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT';
                        field.remove();
                    }
                }, 500);

                // safety net: never leave the spinner up indefinitely
                setTimeout(function () {
                    clearInterval(poll);
                    overlay.hidden = true;
                    if (field.parentNode) {
                        field.remove();
                    }
                }, 300000);
            });
        })();
    </script>
}
