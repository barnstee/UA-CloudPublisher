@using Opc.Ua.Cloud.Publisher.Models

@model SessionModel

@{
    ViewData["Title"] = "Connect to an OPC UA Server";
}

<div class="page-header">
    <h1 class="page-title">@ViewData["Title"]</h1>
    <div class="page-subtitle">Establish a session with an OPC UA server to browse its address space.</div>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-plug"></i> Endpoint</h3>
    <p class="card-subtitle">
        Enter an OPC UA Server's URL to connect to.
    </p>
    <form method="post" enctype="multipart/form-data" asp-controller="Browser" asp-action="UserPassword">
        <p>
            @Html.TextBox("endpointUrl", null, new { @class = "modern-input", placeholder = "opc.tcp://ipaddress:port" })
        </p>
        <p>
            <input id="connectButton" class="btn btn-primary" type="submit" value="Connect">
        </p>
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <p class="uacp-status-error" id="message">@Model.StatusMessage</p>
        }
    </form>
</div>

<div class="app-card">
    <h3 class="card-title"><i class="fas fa-download"></i> Trust Anchor</h3>
    <p class="card-subtitle">
        Download UA Cloud Publisher's OPC UA certificate to establish trust with the OPC UA server manually.
    </p>
    <form method="post" enctype="multipart/form-data" asp-controller="Browser" asp-action="DownloadUACert">
        <p>
            <input class="btn btn-secondary" type="submit" value="Download Certificate">
        </p>
    </form>
</div>
